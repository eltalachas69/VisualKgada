<Window x:Class="Gym2.Views.ManejoEjercicios"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:Gym2.ViewModel"
        mc:Ignorable="d"
        Title="Gestión de Ejercicios" Height="670" Width="1055"
        WindowStartupLocation="CenterScreen"
        Background="#1A1C1E">

    <Window.DataContext>
        <viewModel:ManejoEjerciciosViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="287*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Listado de Ejercicios" Foreground="White" Margin="10,10,10,0" BorderBrush="#3F3F3F">
            <DataGrid ItemsSource="{Binding Ejercicios}" 
                      SelectedItem="{Binding EjercicioSeleccionado}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Background="#25282B" 
                      Foreground="White"
                      BorderThickness="0"
                      RowBackground="#25282B"
                      AlternatingRowBackground="#2D3034">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Músculos" Binding="{Binding MusculosTrabajados}" Width="*"/>
                    <DataGridTextColumn Header="Dificultad" Binding="{Binding Dificultad}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Column="1" Background="#25282B" Margin="10,10,10,0" CornerRadius="10">
            <StackPanel Margin="25">

                <TextBlock Text="Editor de Ejercicio" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBlock Text="Imagen del Ejercicio" Foreground="#ABB2BF" Margin="0,5"/>

                <Border BorderBrush="#3F3F3F" BorderThickness="1" Height="150" Margin="0,5" Background="#1A1C1E">
                    <Grid>
                        <Image Source="{Binding Imagen}" Stretch="Uniform" Margin="5"/>

                        <TextBlock Text="Sin Vista Previa" 
                   Foreground="#3F444A" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Imagen}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <Button Content="Seleccionar Imagen..." 
Command="{Binding SeleccionarImagenCommand}" 
Height="30"
Background="#3E3E42" Foreground="White" Cursor="Hand"/>

                <TextBlock Text="Nombre del Ejercicio" Foreground="#ABB2BF" Margin="0,5"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Músculos Trabajados" Foreground="#ABB2BF" Margin="0,5"/>
                <TextBox Text="{Binding MusculosTrabajados, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Dificultad (1-5)" Foreground="#ABB2BF" Margin="0,5"/>
                <TextBox Text="{Binding Dificultad, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>


                <Button Content="GUARDAR / ACTUALIZAR" 
                        Command="{Binding GuardarCommand}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Height="40" Margin="0,5"/>

                <Button Content="ELIMINAR SELECCIONADO" 
                        Command="{Binding EliminarCommand}" 
                        Background="#E81123" Foreground="White" Height="35" Margin="0,5"/>

                <Button Content="LIMPIAR CAMPOS" 
                        Command="{Binding NuevoCommand}" 
                        Background="#3E3E42" Foreground="White" Height="35" Margin="0,20"/>

                <Button Content="CERRAR VENTANA" Click="btnCerrar_Click"
                        Background="Transparent" Foreground="Gray" BorderBrush="Gray"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>