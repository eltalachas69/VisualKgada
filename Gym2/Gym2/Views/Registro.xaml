<Window x:Class="Gym2.Views.Registro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:Gym2.ViewModel"
        xmlns:conv="clr-namespace:Gym2.Converters"
        mc:Ignorable="d"
        Title="Registro de Usuario" Height="560" Width="800"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.Background>
            <ImageBrush ImageSource="/Images/alien.jpeg" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="10" BorderThickness="2" Opacity="0.95">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#462AD8" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#8A16C1" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,1">
                    <GradientStop Color="#1A1A40" Offset="0"/>
                    <GradientStop Color="#1A1A40" Offset="0.65"/>
                    <GradientStop Color="#37377A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="REGISTRO" Foreground="AntiqueWhite" FontSize="12" 
                               FontFamily="Montserrat" Grid.Column="0" 
                               VerticalAlignment="Center" Margin="10,0,0,0"/>

                    <Button x:Name="btnMinimizar" Content="-" Foreground="White" FontSize="16" 
                            Grid.Column="1" Click="btnMinimizar_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9" Background="#28AEED">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnClose" Content="x" Foreground="White" 
                            Grid.Column="2" Click="btnClose_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9" Background="#DA34AD">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <StackPanel Width="280" Grid.Row="1" Orientation="Vertical" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Image Source="/Images/alien.jpeg" Width="80" Height="80" Margin="0,0,0,10"/>

                    <TextBlock Text="Crear nueva cuenta" Foreground="White" FontSize="18" 
                               FontWeight="Medium" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Grid Margin="0,5">
                        <TextBox x:Name="txtUsuario" Text="{Binding User.Username, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Foreground="White" CaretBrush="White"
                                 BorderBrush="DarkGray" BorderThickness="0,0,0,1" Height="28" 
                                 VerticalContentAlignment="Center" Background="Transparent"/>
                        <TextBlock Text="Usuario" Foreground="Gray" IsHitTestVisible="False" 
                                   VerticalAlignment="Center" Visibility="{Binding Text, ElementName=txtUsuario, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <TextBox x:Name="txtPassword" Text="{Binding User.Password, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Foreground="White" BorderBrush="DarkGray" BorderThickness="0,0,0,1" 
                                 Height="28" VerticalContentAlignment="Center" Background="Transparent"/>
                        <TextBlock Text="Contraseña" Foreground="Gray" IsHitTestVisible="False" 
                                   VerticalAlignment="Center" Visibility="{Binding Text, ElementName=txtPassword, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Grid>

                    <Button x:Name="btnRegistrar" Command="{Binding AddCommand}" Content="REGISTRAR" 
                            Foreground="White" FontSize="14" Cursor="Hand" Margin="0,20,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="150" Height="40" CornerRadius="20" Background="#462AD8">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnCancelar" Content="CANCELAR" Click="btnClose_Click"
                            Foreground="LightGray" FontSize="11" Margin="0,10,0,0" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>