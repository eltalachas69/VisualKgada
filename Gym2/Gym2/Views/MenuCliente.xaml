<Window x:Class="Gym2.Views.MenuCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel del Cliente - Gym2" 
        Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="¡BIENVENIDO!" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Área de Socios" 
                       FontSize="16" 
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"/>
            <Separator Margin="0,10,0,0" Background="#BDC3C7" Width="300"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Rows="2">

            <Button Command="{Binding AbrirSeleccionMembresiaCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="#E0E0E0" 
                                            BorderThickness="1" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <StackPanel>
                    <TextBlock Text="💳" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Escoger Membresía" FontSize="20" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="📋" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Mis Rutinas" FontSize="20" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Mi Perfil" FontSize="20" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding CerrarSesionCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="#FFF5F5" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🚪" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Cerrar Sesión" FontSize="20" FontWeight="SemiBold" Foreground="#C62828"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Window>