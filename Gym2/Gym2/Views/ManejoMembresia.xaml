<Window x:Class="Gym2.Views.ManejoMembresia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:Gym2.ViewModel"
        Title="Gestión de Membresías" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1A1C1E">

    <Window.DataContext>
        <viewModel:ManejoMembresiaViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Membresías Disponibles" Foreground="White" Margin="10" BorderBrush="#3F3F3F">
            <DataGrid ItemsSource="{Binding Membresias}" 
                      SelectedItem="{Binding MembresiaSeleccionada}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Background="#25282B" 
                      Foreground="White"
                      RowBackground="#25282B"
                      AlternatingRowBackground="#2D3034">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Nombre de Membresía" Binding="{Binding Nombre}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Column="1" Background="#25282B" Margin="10" CornerRadius="10">
            <StackPanel Margin="20">
                <TextBlock Text="Editor de Membresía" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Nombre" Foreground="#ABB2BF" Margin="0,5"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                <Button Content="GUARDAR / ACTUALIZAR" 
                        Command="{Binding GuardarCommand}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Height="40" Margin="0,5"/>

                <Button Content="ELIMINAR" 
                        Command="{Binding EliminarCommand}" 
                        Background="#E81123" Foreground="White" Height="35" Margin="0,5"/>

                <Button Content="NUEVO / LIMPIAR" 
                        Command="{Binding NuevoCommand}" 
                        Background="#3E3E42" Foreground="White" Height="35" Margin="0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>