<Window x:Class="Gym2.Views.MenuAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gym2.Views"
        mc:Ignorable="d"
        Title="Panel de Administración - Gym2" 
        Height="550" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="SISTEMA GESTIÓNGYM" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Panel de Control Administrativo" 
                       FontSize="16" 
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"/>
            <Separator Margin="0,10,0,0" Background="#BDC3C7" Width="400"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Rows="2">

            <Button Command="{Binding AbrirClientesCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" BorderBrush="#E0E0E0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="1" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <StackPanel>
                    <TextBlock Text="👥" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Manejo Clientes" FontSize="18" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding AbrirUsuariosCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Manejo Usuarios" FontSize="18" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding AbrirMembresiasCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="💳" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Manejo Membresías" FontSize="18" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding AbrirEjerciciosCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🏋️‍♂️" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Manejo Ejercicios" FontSize="18" FontWeight="SemiBold" Foreground="#34495E"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding AbrirAdminsCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="White" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="👷" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Manejo Admins" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding CerrarSesionCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15" Background="#FFF5F5" BorderBrush="#FFEBEE" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🚪" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Cerrar Sesión" FontSize="18" FontWeight="SemiBold" Foreground="#C62828"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Window>