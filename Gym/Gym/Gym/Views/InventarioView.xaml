<Window x:Class="Gym.Views.InventarioView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario" 
        Height="550" Width="1000"
        WindowStyle="None" 
        WindowStartupLocation="CenterScreen"
        Background="Transparent" 
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="BotonRedondeado" TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" 
                         Value="True">
                    <Setter Property="Opacity" 
                            Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BotonBuscar" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#005A9E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#005A9E" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="SISTEMA DE GESTIÓN" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="15,0,0,0" 
                           FontWeight="Bold" 
                           FontSize="18"/>
                <TextBlock Grid.Column="1" 
                           Text="INVENTARIO" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="0,0,40,0" 
                           FontWeight="Bold" 
                           FontSize="18"/>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,0,10,0">
                    <Button Content="-" 
                            Width="30" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Click="BtnMinimizar_Click"/>
                    <Button Content="X" 
                            Width="30" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16" 
                            Click="BtnCerrar_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Background="#A2BAF5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="6*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" 
                            Grid.Row="0" 
                            Orientation="Horizontal" 
                            Margin="15,10,0,0">
                    <Button Style="{StaticResource BotonRedondeado}" 
                            Background="#32FF32" 
                            Width="60" Height="55" 
                            Margin="0,0,10,0">
                        <TextBlock Text="Agregar&#x0a;producto&#x0a;✓" 
                                   TextAlignment="Center" 
                                   FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BotonRedondeado}" 
                            Background="#32FFFF" 
                            Width="60" Height="55" 
                            Margin="0,0,15,0">
                        <TextBlock Text="Modificar&#x0a;producto&#x0a;✓" 
                                   TextAlignment="Center" 
                                   FontSize="10"/>
                    </Button>
                    <TextBlock Text="Productos" 
                               FontSize="26" 
                               VerticalAlignment="Center" 
                               Margin="10,0,0,15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            Grid.Row="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="0,0,15,0">
                    <Button Style="{StaticResource BotonRedondeado}" 
                            Background="#FF1919" 
                            Foreground="White" 
                            Width="60" Height="55" 
                            Margin="0,0,30,0">
                        <TextBlock Text="Limpiar&#x0a;tablero&#x0a;🗑" 
                                   TextAlignment="Center" 
                                   FontSize="10"/>
                    </Button>

                    <TextBox Width="300" 
                             Height="30" 
                             Text="Busca el nombre o el id del articulo" 
                             Foreground="Gray" 
                             VerticalContentAlignment="Center" 
                             Padding="5,0,0,0"/>
                    <Button Style="{StaticResource BotonBuscar}" 
                            Content="BUSCAR" 
                            Background="#2140D0" 
                            Width="80" Height="30" 
                            Margin="10,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="0" 
                           Grid.Row="1" 
                           Text="Menor stock" 
                           FontWeight="Bold" 
                           FontSize="16" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Bottom" 
                           Margin="0,0,0,5"/>

                <StackPanel Grid.Column="1" 
                            Grid.Row="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Bottom" 
                            Margin="10,0,0,5">
                    <TextBlock Text="Filtrar por" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>

                    <ComboBox Width="60" Margin="0,0,10,0" SelectedIndex="0">
                        <ComboBoxItem Content="ID"/>
                    </ComboBox>
                    <ComboBox Width="90" 
                              Margin="0,0,10,0" 
                              SelectedIndex="0">
                        <ComboBoxItem Content="Nombre"/>
                    </ComboBox>
                    <ComboBox Width="80" 
                              Margin="0,0,10,0" 
                              SelectedIndex="0">
                        <ComboBoxItem Content="Marca"/>
                    </ComboBox>
                    <ComboBox Width="100" 
                              Margin="0,0,0,0" 
                              SelectedIndex="0">
                        <ComboBoxItem Content="Dispositivo"/>
                    </ComboBox>
                </StackPanel>

                <DataGrid Grid.Column="0" Grid.Row="2" Margin="15,0,10,15" Background="White" AutoGenerateColumns="False" RowHeaderWidth="0" GridLinesVisibility="All" BorderBrush="Gray" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Width="0.5*"/>
                        <DataGridTextColumn Header="Nombre del producto" Width="2*"/>
                        <DataGridTextColumn Header="Marca" Width="1*"/>
                        <DataGridTextColumn Header="Dispositivo" Width="1.2*"/>
                        <DataGridTextColumn Header="Precio" Width="1*"/>
                        <DataGridTextColumn Header="t" Width="0.5*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid Grid.Column="1" Grid.Row="2" Margin="10,0,15,15" ItemsSource="{Binding ListaInventario}" Background="White" AutoGenerateColumns="False" RowHeaderWidth="0" GridLinesVisibility="All" BorderBrush="Gray" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Width="0.5*" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Nombre del producto" Width="2.5*" Binding="{Binding Nombre}"/>
                        <DataGridTextColumn Header="Marca" Width="1*" Binding="{Binding Marca}"/>
                        <DataGridTextColumn Header="Dispositivo" Width="1.5*" Binding="{Binding Dispositivo}"/>
                        <DataGridTextColumn Header="Precio" Width="1*" Binding="{Binding Precio}"/>
                        <DataGridTextColumn Header="Stock" Width="1*" Binding="{Binding Stock}"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Grid>
    </Border>
</Window>