<Window x:Class="Gym.Views.PuntoDeVentaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Punto de Venta" 
        Height="600" Width="1000"
        WindowStyle="None" 
        WindowStartupLocation="CenterScreen"
        Background="Transparent" 
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" 
                         Value="True">
                    <Setter Property="Opacity" 
                            Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BotonBuscar" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" BorderBrush="#005A9E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#005A9E" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="SISTEMA DE GESTIÓN" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" FontSize="18"/>
                <TextBlock Grid.Column="1" Text="PUNTO DE VENTA" Foreground="White" VerticalAlignment="Center" Margin="0,0,40,0" FontWeight="Bold" FontSize="18"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="-" Width="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Click="BtnMinimizar_Click"/>
                    <Button Content="X" Width="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Click="BtnCerrar_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EAF8F8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource BotonAccion}" Background="#32FF32" Width="60" Height="55" Margin="5,0,0,0">
                                <TextBlock Text="Confirmar&#x0a;Venta&#x0a;✓" Foreground="White" FontSize="10" TextAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <TextBlock Grid.Column="1" Text="VENTA&#x0a;ACTUAL" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>

                            <Button Grid.Column="2" Style="{StaticResource BotonAccion}" Background="#FF1919" Foreground="White" Width="60" Height="55" Margin="0,0,5,0" Command="{Binding LimpiarVentaCommand}">
                                <TextBlock Text="Limpiar&#x0a;tablero&#x0a;🗑" TextAlignment="Center" FontSize="10"/>
                            </Button>
                        </Grid>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ProductosEnVenta}" Background="White" AutoGenerateColumns="False" RowHeaderWidth="0" GridLinesVisibility="All" BorderBrush="Gray" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Width="0.5*" Binding="{Binding Id}"/>
                                <DataGridTextColumn Header="NOMBRE DEL PRODUCTO" Width="2.5*" Binding="{Binding Nombre}"/>
                                <DataGridTextColumn Header="CANTIDAD" Width="1*" Binding="{Binding Cantidad}"/>
                                <DataGridTextColumn Header="PRECIO" Width="1*" Binding="{Binding Precio}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="PRODUCTOS&#x0a;TOTALES" FontWeight="Bold" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalProductos, FallbackValue='1'}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="Total de la&#x0a;venta" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Right" FontSize="12" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="3" Text="$0" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#A2BAF5" BorderBrush="#7092E0" BorderThickness="2" Margin="5,10,10,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <TextBox x:Name="txtBusqueda" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
                                <TextBlock Text="Busca el nombre o el id del articulo" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=txtBusqueda}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Button Grid.Column="1" Style="{StaticResource BotonBuscar}" Content="BUSCAR" Background="#2140D0" Width="80" Height="30" Command="{Binding BuscarCommand}"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Filtrar por" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox SelectedItem="{Binding FiltroSeleccionado}" Width="60" Margin="0,0,10,0" SelectedIndex="0">
                                <ComboBoxItem Content="ID"/>
                            </ComboBox>
                            <ComboBox Width="90" Margin="0,0,10,0" SelectedIndex="0">
                                <ComboBoxItem Content="Nombre"/>
                            </ComboBox>
                            <ComboBox Width="80" Margin="0,0,10,0" SelectedIndex="0">
                                <ComboBoxItem Content="Marca"/>
                            </ComboBox>
                            <ComboBox Width="100" SelectedIndex="0">
                                <ComboBoxItem Content="Dispositivo"/>
                            </ComboBox>
                        </StackPanel>

                        <DataGrid Grid.Row="2" ItemsSource="{Binding ProductosInventario}" SelectedItem="{Binding ProductoSeleccionado}" Background="White" AutoGenerateColumns="False" RowHeaderWidth="0" GridLinesVisibility="All" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Width="0.5*" Binding="{Binding Id}"/>
                                <DataGridTextColumn Header="Nombre del producto" Width="2*" Binding="{Binding Nombre}"/>
                                <DataGridTextColumn Header="Marca" Width="1*" Binding="{Binding Marca}"/>
                                <DataGridTextColumn Header="Dispositivo" Width="1.5*" Binding="{Binding Dispositivo}"/>
                                <DataGridTextColumn Header="Precio" Width="1*" Binding="{Binding Precio}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="3" Background="#1A7A1A" Foreground="White" Width="150" Height="50" HorizontalAlignment="Right" Command="{Binding AgregarAVentaCommand}">
                            <Border CornerRadius="10">
                                <TextBlock Text="AGREGAR A LA&#x0a;VENTA" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>